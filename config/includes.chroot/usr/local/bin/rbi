#!/bin/bash

echo "================================"
echo "  Rainbow Bridge OS Installer"
echo "================================"
echo ""

# List available disks
echo "Available disks:"
lsblk -d -o NAME,SIZE,MODEL | grep -v loop
echo ""

read -p "Enter disk to install to (e.g. sda): " DISK
DISK="/dev/$DISK"

echo ""
echo "WARNING: This will ERASE all data on $DISK"
read -p "Are you sure? (yes/no): " CONFIRM

if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted."
    exit 1
fi

echo ""
echo "[1/5] Partitioning $DISK..."
parted -s $DISK mklabel gpt
parted -s $DISK mkpart ESP fat32 1MiB 512MiB
parted -s $DISK set 1 esp on
parted -s $DISK mkpart ROOT ext4 512MiB 100%

echo "[2/5] Formatting..."
mkfs.fat -F32 ${DISK}1
mkfs.ext4 -F ${DISK}2

echo "[3/5] Mounting..."
mount ${DISK}2 /mnt
mkdir -p /mnt/boot/efi
mount ${DISK}1 /mnt/boot/efi

echo "[4/5] Installing system..."
rsync -a --exclude=/proc --exclude=/sys --exclude=/dev --exclude=/run --exclude=/mnt / /mnt/

echo "[5/5] Installing bootloader..."
grub-install --target=x86_64-efi --efi-directory=/mnt/boot/efi --boot-directory=/mnt/boot --removable
grub-mkconfig -o /mnt/boot/grub/grub.cfg

echo ""
echo "================================"
echo "  Installation complete!"
echo "  You can now reboot."
echo "================================"
